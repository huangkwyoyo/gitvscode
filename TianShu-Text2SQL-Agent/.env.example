# TianShu Text2SQL Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 注意：.env 文件包含敏感信息，已在 .gitignore 中排除，请勿提交到版本控制。

# ── 本地 API 令牌（Phase 6C 本地安全模式必需） ──
# 至少 32 个字符，用于 X-TianShu-Token 请求头认证
# 生成建议：python -c "import secrets; print(secrets.token_urlsafe(32))"
TIANSHU_LOCAL_API_TOKEN=your-token-here-min-32-chars-long

# ── Python 编码（Windows 建议设置） ──
# 避免 GBK 控制台编码导致的乱码问题
PYTHONIOENCODING=utf-8

# ── 真实 DuckDB E2E 测试（可选） ──
# 设为 1 以启用需要真实数据库的端到端测试（pytest -m real_duckdb）
# TIANSHU_RUN_REAL_E2E=1

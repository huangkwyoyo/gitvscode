#!/bin/bash
# ============================================================
# TianShu Text2SQL Agent 快速门禁 pre-commit hook
#
# 在 git commit 前自动运行离线质量检查。
# 通过 → 允许提交
# 失败 → 阻断提交，显示失败项和修复建议
#
# 安装方式（开发者本地一次性操作）：
#   git config core.hooksPath .githooks
#
# 如需跳过（不推荐）：
#   git commit --no-verify
# ============================================================

set -euo pipefail

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 项目根目录
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

echo ""
echo -e "${CYAN}═══════════════════════════════════════════════════════${NC}"
echo -e "${CYAN}  TianShu Text2SQL Agent — 快速门禁 (pre-commit)${NC}"
echo -e "${CYAN}═══════════════════════════════════════════════════════${NC}"
echo ""

# ── 第一步：代码编译检查 ──────────────────────────────
echo -e "${YELLOW}[1/5] 代码编译检查 (compileall)...${NC}"
if python -m compileall -q src harness tests 2>/dev/null; then
    echo -e "  ${GREEN}✅ PASS${NC} — 所有 Python 文件编译通过"
else
    echo -e "  ${RED}❌ FAIL${NC} — 存在语法错误的 Python 文件"
    echo ""
    echo -e "  ${YELLOW}修复建议：${NC}"
    echo "    运行 python -m compileall src harness tests 查看具体错误"
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  快速门禁未通过 — commit 已阻断${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo ""
    echo "  跳过方式（不推荐）：git commit --no-verify"
    exit 1
fi

# ── 第二步：单元测试 ──────────────────────────────────
echo -e "${YELLOW}[2/5] 单元测试 (pytest)...${NC}"
if python -m pytest -q --basetemp harness/reports/test_tmp/pytest_precommit_hook 2>&1; then
    echo -e "  ${GREEN}✅ PASS${NC} — 所有测试用例通过"
else
    echo ""
    echo -e "  ${YELLOW}修复建议：${NC}"
    echo "    运行 python -m pytest -v 查看失败用例详情"
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  快速门禁未通过 — commit 已阻断${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo ""
    echo "  跳过方式（不推荐）：git commit --no-verify"
    exit 1
fi

# ── 第三步：Harness 五项安全检查 ──────────────────────────
echo -e "${YELLOW}[3/5] Harness 五项安全检查...${NC}"
if python harness/run_harness.py --step 1 2>&1 && \
   python harness/run_harness.py --step 2 2>&1 && \
   python harness/run_harness.py --step 3 2>&1 && \
   python harness/run_harness.py --step 4 2>&1 && \
   python harness/run_harness.py --step 5 2>&1; then
    echo -e "  ${GREEN}✅ PASS${NC} — 五项安全检查全部通过"
else
    echo ""
    echo -e "  ${YELLOW}修复建议：${NC}"
    echo "    运行 python harness/run_harness.py 查看失败项详情"
    echo "    — SQL 只读安全门禁（禁止写操作）"
    echo "    — IR 数据结构完整性（三层 IR 定义）"
    echo "    — 反问/拒绝策略完备性（refusal policy）"
    echo "    — 层级合规门禁（G3 > G2 > Silver > Bronze）"
    echo "    — 指标注册合规门禁（metric 必须在 registry 中）"
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  快速门禁未通过 — commit 已阻断${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo ""
    echo "  跳过方式（不推荐）：git commit --no-verify"
    exit 1
fi

# ── 第四步：Memory Gate 记忆更新检查 ────────────────────
echo -e "${YELLOW}[4/5] Memory Gate 记忆更新检查...${NC}"
MEMORY_OUTPUT=$(python harness/checks/check_memory_update.py 2>&1)
MEMORY_EXIT=$?
if [ $MEMORY_EXIT -eq 0 ]; then
    echo -e "  ${GREEN}✅ PASS${NC} — 记忆更新检查通过"
else
    echo "$MEMORY_OUTPUT"
    echo ""
    echo -e "  ${YELLOW}修复建议：${NC}"
    echo "    检测到关键路径变更但未同步更新记忆文件。"
    echo "    请在 docs/memory/经验复盘.md 中补写经验条目。"
    echo "    模板参考：docs/memory/变更复盘模板.md"
    echo "    重新检查：python harness/checks/check_memory_update.py"
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  快速门禁未通过 — commit 已阻断${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════${NC}"
    echo ""
    echo "  跳过方式（不推荐）：git commit --no-verify"
    exit 1
fi

# ── 第五步：Memory Harness pre-commit warn（warn-only，不阻断）──
echo -e "${YELLOW}[5/5] Memory Harness pre-commit warn（warn-only）...${NC}"
python harness/run_precommit_memory_warn.py --record-observation 2>&1
# pre-commit warn 始终为 warn-only，不检查其退出码，不阻断 commit
echo -e "  ${CYAN}ℹ️  以上为 Memory Harness 检查结果（warn-only，不影响 commit）${NC}"

# ── 全部通过 ──────────────────────────────────────────
echo ""
echo -e "${GREEN}═══════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  快速门禁全部通过 ✅ — 允许提交${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════${NC}"
echo ""

exit 0

#!/usr/bin/env bash
# TianShu pre-commit 门禁
#
# 每次提交前自动执行：
#   1. Memory Gate — 关键变更是否同步写入 docs/memory
#   2. 危险模式扫描 — 禁止 DATE::INT 等已知危险写法
#   3. pytest 回归测试 — 字典一致性和 Harness 自检
#
# 本 hook 不依赖 DuckDB，可在 DBeaver 占用数据库时正常运行。
# 完整 Harness（含 schema 一致性和 Silver NULL 检查）请手动运行：
#   python scripts/quality/run_all_checks.py

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass_count=0
fail_count=0

run_check() {
    local name="$1"
    shift
    printf "${YELLOW}[RUN]${NC} %s ... " "$name"
    local tmpout
    tmpout="$(mktemp)"
    if "$@" > "$tmpout" 2>&1; then
        printf "${GREEN}OK${NC}\n"
        pass_count=$((pass_count + 1))
        rm -f "$tmpout"
        return 0
    else
        printf "${RED}FAIL${NC}\n"
        # 显示失败详情，帮助定位问题
        if [ -s "$tmpout" ]; then
            echo ""
            cat "$tmpout" | while IFS= read -r line; do
                printf "  ${RED}▎${NC} %s\n" "$line"
            done
            echo ""
        fi
        rm -f "$tmpout"
        fail_count=$((fail_count + 1))
        return 1
    fi
}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  TianShu Pre-commit Gate"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 1. Memory Gate (不依赖 DB)
run_check "Memory Gate" python scripts/quality/check_memory_update.py

# 2. 危险模式扫描 (不依赖 DB)
run_check "危险模式扫描" python scripts/quality/check_dangerous_patterns.py --dir "$REPO_ROOT"

# 3. pytest 回归测试
run_check "Silver 字典回归测试" python -m pytest tests/test_silver_dictionary.py -q
run_check "Harness 自检回归测试" python -m pytest tests/test_harness_quality.py -q

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $fail_count -eq 0 ]; then
    printf "${GREEN}Pre-commit 全部通过 (%d/%d)${NC}\n" $pass_count $((pass_count + fail_count))
    echo ""
    exit 0
else
    printf "${RED}Pre-commit 失败: %d 项未通过${NC}\n" $fail_count
    echo ""
    echo "修复指引："
    echo "  • Memory Gate 失败 → 在对话中说「把这次经验写入记忆」，让 Agent 帮你更新"
    echo "  • 危险模式扫描失败 → 检查上方的违规项，修复后重新提交"
    echo "  • pytest 失败 → 检查测试输出，确保数据字典与实表一致"
    echo ""
    echo "完整 Harness（含 DB 检查）：python scripts/quality/run_all_checks.py"
    echo ""
    exit 1
fi

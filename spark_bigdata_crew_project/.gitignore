# ============================================================
# 敏感信息 — 严禁提交
# ============================================================
.env
.env.*
*.pem
*.key
credentials.json
service-account.json

# 注意：config/llm_config.json 不含密钥（密钥在.env中），需要提交
!config/llm_config.json

# ============================================================
# Python 缓存与编译产物
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
*.whl

# ============================================================
# 虚拟环境
# ============================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
pyenv/

# ============================================================
# 运行时产出 — 全部由流水线生成，不应入库
# ============================================================
output/
spark_code_git_repo/

# ============================================================
# 日志与临时文件
# ============================================================
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# ============================================================
# IDE 与编辑器
# ============================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.history/

# ============================================================
# Claude Code 本地配置
# ============================================================
.claude/

# ============================================================
# 操作系统
# ============================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Jupyter Notebook
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# PySpark
# ============================================================
metastore_db/
derby.log
spark-warehouse/
